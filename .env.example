# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real secrets. This `.env.example` must
# contain placeholders only.

# --- Shopify ---
# During local development `shopify app dev` injects these automatically, so you
# usually do NOT need them here. Set them explicitly when self-hosting in
# production (e.g. on the Hostinger subdomain). Values come from the app's
# Settings > Credentials page in the Shopify dashboard.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated access scopes (must match shopify.app.toml [access_scopes]).
SCOPES=
# Public URL of the deployed app, e.g. https://webstore.baisajaipur.in
SHOPIFY_APP_URL=

# --- Supabase (business-data backend) ---
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# Anon/public key — safe for browser/client use (RLS applies). Reserved for any
# future client-side access; the server backend uses the service-role key below.
SUPABASE_ANON_KEY=
# Service-role key — SERVER-ONLY. Bypasses Row Level Security. Used by
# app/supabase.server.ts. Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=
