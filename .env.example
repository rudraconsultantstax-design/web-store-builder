# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — NEVER commit real secrets. This `.env.example` must
# contain placeholders only.

# --- Shopify ---
# During local development `shopify app dev` injects these automatically, so you
# usually do NOT need them here. Set them explicitly when self-hosting in
# production (e.g. on the Hostinger subdomain). Values come from the app's
# Settings > Credentials page in the Shopify dashboard.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated access scopes (must match shopify.app.toml [access_scopes]).
SCOPES=
# Public URL of the deployed app, e.g. https://webstore.baisajaipur.in
SHOPIFY_APP_URL=

# --- Supabase (business-data backend) ---
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# Anon/public key — safe for browser/client use (RLS applies). Reserved for any
# future client-side access; the server backend uses the service-role key below.
SUPABASE_ANON_KEY=
# Service-role key — SERVER-ONLY. Bypasses Row Level Security. Used by
# app/supabase.server.ts. Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma session storage (Postgres / Supabase) ---
# Sessions are stored in Postgres (not SQLite) so they persist on serverless
# hosts like Vercel, whose filesystem is ephemeral. Point these at the same
# Supabase project as above (Project Settings > Database > Connection string).
#
# Runtime connection — the Supabase connection pooler (PgBouncer). Use the
# pooled host on port 6543 with ?pgbouncer=true. Prisma uses this at runtime.
# e.g. postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
# Direct (non-pooled) connection on port 5432. Prisma uses this for migrations
# / `prisma db push` (DDL), which PgBouncer's transaction mode cannot run.
# e.g. postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=
